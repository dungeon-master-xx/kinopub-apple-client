    "Caps streaming quality. Auto lets the player adapt to your connection.": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Strim keyfiyyətini məhdudlaşdırır. «Avto» — pleyer özü bağlantıya uyğunlaşır."
          }
        },
        "be": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Абмяжоўвае якасць струменя. «Аўта» — плэер сам падладжваецца пад злучэнне."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Caps streaming quality. Auto lets the player adapt to your connection."
          }
        },
        "et": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Piirab voo kvaliteeti. „Auto“ laseb mängijal ühendusega kohaneda."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Սահմանափակում է հոսքի որակը։ «Ավտո»՝ նվագարկիչն ինքն է հարմարվում կապին։"
          }
        },
        "ka": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ზღუდავს სტრიმის ხარისხს. „ავტო“ — დამკვრელი თავად ერგება კავშირს."
          }
        },
        "kk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Стрим сапасын шектейді. «Авто» — плеер байланысқа өзі бейімделеді."
          }
        },
        "ky": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Стримдин сапатын чектейт. «Авто» — плеер байланышка өзү ыңгайлашат."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Riboja transliacijos kokybę. „Auto“ leidžia grotuvui prisitaikyti prie jūsų ryšio."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Ierobežo straumēšanas kvalitāti. “Auto” ļauj atskaņotājam pielāgoties savienojumam."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Limitează calitatea streamingului. „Auto” lasă playerul să se adapteze la conexiunea ta."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ограничивает качество стрима. «Авто» — плеер сам подстраивается под соединение."
          }
        },
        "tg": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Сифати стримро маҳдуд мекунад. «Худкор» — плеер худаш ба пайвасти шумо мутобиқ мешавад."
          }
        },
        "tk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Akym hilini çäklendirýär. «Awto» — pleýer baglanyşyga öz-özi uýgunlaşýar."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Обмежує якість стрімінгу. «Авто» — плеєр сам підлаштовується під з’єднання."
          }
        },
        "uz": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Strim sifatini cheklaydi. «Avto» — pleyer ulanishingizga oʻzi moslashadi."
          }
        }
      }
    },
