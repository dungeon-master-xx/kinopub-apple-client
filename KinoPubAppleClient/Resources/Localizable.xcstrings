    "You don't have any downloads yet": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Hələ heç bir yükləməniz yoxdur"
          }
        },
        "be": {
          "stringUnit": {
            "state": "needs_review",
            "value": "У вас пакуль няма спамповак"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You don't have any downloads yet"
          }
        },
        "et": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Sul pole veel ühtegi allalaadimist"
          }
        },
        "hy": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Դեռ ներբեռնումներ չունեք"
          }
        },
        "ka": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ჯერ არ გაქვთ ჩამოტვირთვები"
          }
        },
        "kk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Сізде әзірге жүктеулер жоқ"
          }
        },
        "ky": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Сизде азырынча жүктөөлөр жок"
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Neturite dar atsisiuntimų"
          }
        },
        "lv": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Jums pagaidām nav lejupielāžu"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Încă nu ai nicio descărcare"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "У вас пока нет загрузок"
          }
        },
        "tg": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Шумо ҳоло боргирӣ надоред"
          }
        },
        "tk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Sizde heniz ýükleme ýok"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "У вас поки немає завантажень"
          }
        },
        "uz": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Sizda hozircha yuklanmalar yoʻq"
          }
        }
      }
    },
    "You're offline — your downloads are available": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Şəbəkə yoxdur — yükləmələr əlçatandır"
          }
        },
        "be": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Няма сеткі — даступныя спампоўкі"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You're offline — your downloads are available"
          }
        },
        "et": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Oled võrguühenduseta — allalaadimised on saadaval"
          }
        },
        "hy": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Ցանց չկա՝ հասանելի են ներբեռնումները"
          }
        },
        "ka": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ქსელი არ არის — ხელმისაწვდომია ჩამოტვირთვები"
          }
        },
        "kk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Желі жоқ — жүктеулер қолжетімді"
          }
        },
        "ky": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Тармак жок — жүктөөлөр жеткиликтүү"
          }
        },
        "lt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Nėra ryšio — pasiekiami atsisiuntimai"
          }
        },
        "lv": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Nav tīkla — pieejamas lejupielādes"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Ești offline — descărcările tale sunt disponibile"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нет сети — доступны загрузки"
          }
        },
        "tg": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Шабака нест — боргириҳо дастрасанд"
          }
        },
        "tk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Tor ýok — ýüklemeler elýeterli"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Немає мережі — доступні завантаження"
          }
        },
        "uz": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Tarmoq yoʻq — yuklanmalar mavjud"
          }
        }
      }
    },
    "You've already rated this": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Artıq qiymət vermisiniz — dəyişmək olmaz"
          }
        },
        "be": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Вы ўжо ацанілі — змяніць нельга"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You've already rated this"
          }
        },
        "et": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Oled selle juba hinnanud"
          }
        },
        "hy": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Արդեն գնահատել եք՝ փոխել հնարավոր չէ"
          }
        },
        "ka": {
          "stringUnit": {
            "state": "needs_review",
            "value": "უკვე შეაფასეთ — შეცვლა შეუძლებელია"
          }
        },
        "kk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Сіз баға бергенсіз — өзгерту мүмкін емес"
          }
        },
        "ky": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Сиз буга баа берип койгонсуз — өзгөртүүгө болбойт"
          }
        },
        "lt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Jau įvertinote — pakeisti negalima"
          }
        },
        "lv": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Jūs jau esat novērtējis — mainīt nav iespējams"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Ai evaluat deja acest titlu"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы уже оценили — изменить нельзя"
          }
        },
        "tg": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Шумо аллакай баҳо додаед — тағйир додан мумкин нест"
          }
        },
        "tk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Eýýäm baha berdiňiz — üýtgedip bolmaýar"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Ви вже оцінили — змінити не можна"
          }
        },
        "uz": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Siz allaqachon baho bergansiz — oʻzgartirib boʻlmaydi"
          }
        }
      }
    },
