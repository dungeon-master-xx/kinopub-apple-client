    "Added to watchlist": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "needs_review",
            "value": "«Baxıram» siyahısına əlavə edildi"
          }
        },
        "be": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Дададзена ў «Я гляджу»"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Added to watchlist"
          }
        },
        "et": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Lisatud vaatamisnimekirja"
          }
        },
        "hy": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Ավելացվեց «Դիտում եմ» ցանկում"
          }
        },
        "ka": {
          "stringUnit": {
            "state": "needs_review",
            "value": "დამატებულია „ვუყურებ“-ში"
          }
        },
        "kk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "«Қарап жатырмын» тізіміне қосылды"
          }
        },
        "ky": {
          "stringUnit": {
            "state": "needs_review",
            "value": "«Мен көрүп жатам» тизмесине кошулду"
          }
        },
        "lt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Pridėta į „Žiūriu“"
          }
        },
        "lv": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Pievienots sarakstam"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Adăugat în listă"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Добавлено в «Я смотрю»"
          }
        },
        "tg": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Ба «Ман тамошо мекунам» илова шуд"
          }
        },
        "tk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "«Görýärin» sanawyna goşuldy"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Додано до «Я дивлюся»"
          }
        },
        "uz": {
          "stringUnit": {
            "state": "needs_review",
            "value": "«Koʻraman»ga qoʻshildi"
          }
        }
      }
    },
