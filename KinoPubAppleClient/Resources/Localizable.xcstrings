        "hy": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Եղեք առաջինը, ով կքննարկի այս ֆիլմը"
          }
        },
        "ka": {
          "stringUnit": {
            "state": "needs_review",
            "value": "იყავით პირველი, ვინც ამ ტაიტლს განიხილავს"
          }
        },
        "kk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Осы тайтлды талқылаған бірінші болыңыз"
          }
        },
        "ky": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Бул тайтлды биринчи болуп талкуулаңыз"
          }
        },
        "lt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Būkite pirmas, aptaręs šį tinklalapį"
          }
        },
        "lv": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Esiet pirmais, kas apspriež šo nosaukumu"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Fii primul care discută acest titlu"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Будьте первым, кто обсудит этот тайтл"
          }
        },
        "tg": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Аввалин шуда ин тайтлро муҳокима кунед"
          }
        },
        "tk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Bu taýtly ara alyp maslahatlaşan ilkinji boluň"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Будьте першим, хто обговорить цей тайтл"
