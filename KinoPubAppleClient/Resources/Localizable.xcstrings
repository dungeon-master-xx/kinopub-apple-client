    "The app will restart to apply the language change.": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Dil dəyişikliyini tətbiq etmək üçün tətbiq bağlanacaq."
          }
        },
        "be": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Праграма закрыецца, каб захаваць змену мовы."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The app will close to apply the language change."
          }
        },
        "et": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Rakendus sulgub, et rakendada keelemuudatus."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Հավելվածը կփակվի՝ լեզվի փոփոխությունը պահպանելու համար։"
          }
        },
        "ka": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ენის ცვლილების შესანახად აპი დაიხურება."
          }
        },
        "kk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Тіл өзгерісін сақтау үшін қолданба жабылады."
          }
        },
        "ky": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Тил өзгөртүүнү сактоо үчүн тиркеме жабылат."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Programa išsijungs, kad būtų išsaugoti kalbos pasikeitimai."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Lietotne aizvērsies, lai lietotu valodas izmaiņas."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Aplicația se va închide pentru a aplica schimbarea limbii."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Программа выйдет, чтобы сохранить изменения языка."
          }
        },
        "tg": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Барнома пӯшида мешавад, то тағйири забон сабт шавад."
          }
        },
        "tk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Dil üýtgemesini saklamak üçin programma ýapylar."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Застосунок закриється, щоб застосувати зміну мови."
          }
        },
        "uz": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Til oʻzgarishini saqlash uchun ilova yopiladi."
          }
        }
      }
    },
