    "“%@” failed to download (no file was produced).": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "needs_review",
            "value": "«%@» yüklənə bilmədi (heç bir fayl yaradılmadı)."
          }
        },
        "be": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Не ўдалося спампаваць «%@» (файл не быў створаны)."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "“%@” failed to download (no file was produced)."
          }
        },
        "et": {
          "stringUnit": {
            "state": "needs_review",
            "value": "„%@“ allalaadimine ebaõnnestus (faili ei loodud)."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Չհաջողվեց ներբեռնել «%@» (ֆայլը չստեղծվեց)։"
          }
        },
        "ka": {
          "stringUnit": {
            "state": "needs_review",
            "value": "„%@“-ის ჩამოტვირთვა ვერ მოხერხდა (ფაილი არ შეიქმნა)."
          }
        },
        "kk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "«%@» жүктелмеді (файл жасалмады)."
          }
        },
        "ky": {
          "stringUnit": {
            "state": "needs_review",
            "value": "«%@» жүктөлбөй калды (файл түзүлгөн жок)."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Nepavyko atsisiųsti „%@“ (failas nebuvo sukurtas)."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "needs_review",
            "value": "“%@” neizdevās lejupielādēt (fails netika izveidots)."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "needs_review",
            "value": "„%@” nu a putut fi descărcat (nu a fost creat niciun fișier)."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось загрузить «%@» (файл не был создан)."
          }
        },
        "tg": {
          "stringUnit": {
            "state": "needs_review",
            "value": "«%@»-ро боргирӣ кардан нашуд (файл сохта нашуд)."
          }
        },
        "tk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "«%@» ýüklenmedi (faýl döredilmedi)."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Не вдалося завантажити «%@» (файл не було створено)."
          }
        },
        "uz": {
          "stringUnit": {
            "state": "needs_review",
            "value": "«%@» yuklab olinmadi (fayl yaratilmadi)."
          }
        }
