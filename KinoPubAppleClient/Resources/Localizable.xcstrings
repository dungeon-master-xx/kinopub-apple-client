    "Used to show cast & crew photos. Get a free API key at themoviedb.org.": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Aktyorların və çəkiliş qrupunun fotolarını göstərmək üçün istifadə olunur. Pulsuz açarı themoviedb.org saytından əldə edə bilərsiniz."
          }
        },
        "be": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Выкарыстоўваецца для паказу фота акцёраў і здымачнай групы. Бясплатны ключ можна атрымаць на themoviedb.org."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Used to show cast & crew photos. Get a free API key at themoviedb.org."
          }
        },
        "et": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Kasutatakse näitlejate ja võttegrupi fotode kuvamiseks. Tasuta API võtme saad aadressilt themoviedb.org."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Օգտագործվում է դերասանների և նկարահանող խմբի լուսանկարները ցույց տալու համար։ Անվճար բանալի կարող եք ստանալ themoviedb.org-ում։"
          }
        },
        "ka": {
          "stringUnit": {
            "state": "needs_review",
            "value": "გამოიყენება მსახიობებისა და გადამღები ჯგუფის ფოტოების საჩვენებლად. უფასო API გასაღების მიღება შეგიძლიათ themoviedb.org-ზე."
          }
        },
        "kk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Актёрлер мен түсіру тобының фотоларын көрсету үшін қолданылады. Тегін кілтті themoviedb.org сайтынан алуға болады."
          }
        },
        "ky": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Актёрлордун жана тартуу тобунун сүрөттөрүн көрсөтүү үчүн колдонулат. Акысыз API ачкычын themoviedb.org дегенден алууга болот."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Naudojama aktorių ir filmavimo grupės nuotraukoms rodyti. Nemokamą API raktą gaukite themoviedb.org."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Izmanto, lai rādītu aktieru un komandas fotoattēlus. Bezmaksas API atslēgu varat iegūt vietnē themoviedb.org."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Folosit pentru a afișa fotografiile distribuției și echipei. Obține o cheie API gratuită la themoviedb.org."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Используется для показа фото актёров и съёмочной группы. Бесплатный ключ можно получить на themoviedb.org."
          }
        },
        "tg": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Барои нишон додани аксҳои ҳунарпешагон ва гурӯҳи эҷодӣ истифода мешавад. Калиди ройгонро дар themoviedb.org гирифтан мумкин аст."
          }
        },
        "tk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Aktýorlaryň we surata düşüriş toparynyň suratlaryny görkezmek üçin ulanylýar. Mugt API açaryny themoviedb.org saýtyndan alyp bilersiňiz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Використовується для показу фото акторів і знімальної групи. Безкоштовний ключ можна отримати на themoviedb.org."
          }
        },
        "uz": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Aktyorlar va suratga olish guruhi fotosuratlarini koʻrsatish uchun. Bepul API kalitini themoviedb.org saytidan olishingiz mumkin."
          }
        }
      }
    },
