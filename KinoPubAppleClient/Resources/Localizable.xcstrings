    "Couldn't start downloading “%@” (the server didn't return a valid HLS stream).": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "needs_review",
            "value": "«%@» yükləməsi başlana bilmədi (server düzgün HLS axını qaytarmadı)."
          }
        },
        "be": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Не ўдалося пачаць спампоўку «%@» (сервер не вярнуў карэктны HLS-струмень)."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn't start downloading “%@” (the server didn't return a valid HLS stream)."
          }
        },
        "et": {
          "stringUnit": {
            "state": "needs_review",
            "value": "„%@“ allalaadimist ei õnnestunud alustada (server ei tagastanud korrektset HLS-voogu)."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Չհաջողվեց սկսել «%@»-ի ներբեռնումը (սերվերը չվերադարձրեց վավեր HLS հոսք)։"
          }
        },
        "ka": {
          "stringUnit": {
            "state": "needs_review",
            "value": "„%@“-ის ჩამოტვირთვის დაწყება ვერ მოხერხდა (სერვერმა ვერ დააბრუნა სწორი HLS-ნაკადი)."
          }
        },
        "kk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "«%@» жүктеуін бастау мүмкін болмады (сервер дұрыс HLS-ағынын қайтармады)."
          }
        },
        "ky": {
          "stringUnit": {
            "state": "needs_review",
            "value": "«%@» жүктөөнү баштоо мүмкүн болбоду (сервер туура HLS-агымды кайтарган жок)."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Nepavyko pradėti atsisiųsti „%@“ (serveris negrąžino tinkamo HLS srauto)."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Neizdevās sākt “%@” lejupielādi (serveris neatgrieza derīgu HLS straumi)."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Descărcarea „%@” nu a putut fi pornită (serverul nu a returnat un flux HLS valid)."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось начать загрузку «%@» (сервер не вернул корректный HLS-поток)."
          }
        },
        "tg": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Боргирии «%@»-ро оғоз кардан нашуд (сервер стрими дурусти HLS барнагардонд)."
          }
        },
        "tk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "«%@» ýüklemesini başladyp bolmady (serwer dogry HLS akymyny gaýtaryp bermedi)."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Не вдалося розпочати завантаження «%@» (сервер не повернув коректний HLS-потік)."
          }
        },
        "uz": {
          "stringUnit": {
            "state": "needs_review",
            "value": "«%@» yuklab olishni boshlab boʻlmadi (server toʻgʻri HLS oqimini qaytarmadi)."
          }
        }
      }
    },
