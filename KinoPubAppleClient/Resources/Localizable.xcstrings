    "Find movies, shows, actors and directors.": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Filmlər, seriallar, aktyorlar və rejissorlar."
          }
        },
        "be": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Фільмы, серыялы, акцёры і рэжысёры."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Find movies, shows, actors and directors."
          }
        },
        "et": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Filmid, sarjad, näitlejad ja režissöörid."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Ֆիլմեր, սերիալներ, դերասաններ և ռեժիսորներ։"
          }
        },
        "ka": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ფილმები, სერიალები, მსახიობები და რეჟისორები."
          }
        },
        "kk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Фильмдер, сериалдар, актёрлер мен режиссёрлер."
          }
        },
        "ky": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Фильмдер, сериалдар, актёрлор жана режиссёрлор."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Filmai, serialai, aktoriai ir režisieriai."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Filmas, seriāli, aktieri un režisori."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Filme, seriale, actori și regizori."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Фильмы, сериалы, актёры и режиссёры."
          }
        },
        "tg": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Филмҳо, сериалҳо, ҳунарпешагон ва коргардонҳо."
          }
        },
        "tk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Filmler, seriallar, aktýorlar we režissýorlar."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Фільми, серіали, актори та режисери."
          }
        },
        "uz": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Filmlar, seriallar, aktyorlar va rejissyorlar."
          }
        }
      }
    },
