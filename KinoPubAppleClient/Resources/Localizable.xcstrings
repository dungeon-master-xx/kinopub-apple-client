    "Remove devices you no longer use. The current device can't be removed here — use Logout.": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "needs_review",
            "value": "İstifadə etmədiyiniz cihazları silin. Cari cihazı buradan silmək olmaz — «Çıxış»dan istifadə edin."
          }
        },
        "be": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Выдаляйце прылады, якімі не карыстаецеся. Бягучую прыладу адсюль выдаліць нельга — скарыстайцеся «Выйсці»."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Remove devices you no longer use. The current device can't be removed here — use Logout."
          }
        },
        "et": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Eemalda seadmed, mida enam ei kasuta. Praegust seadet siit eemaldada ei saa — kasuta „Logi välja“."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Հեռացրեք սարքերը, որոնք այլևս չեք օգտագործում։ Ընթացիկ սարքն այստեղից հնարավոր չէ հեռացնել՝ օգտագործեք «Դուրս գալ»։"
          }
        },
        "ka": {
          "stringUnit": {
            "state": "needs_review",
            "value": "წაშალეთ მოწყობილობები, რომლებსაც აღარ იყენებთ. მიმდინარე მოწყობილობის აქედან წაშლა შეუძლებელია — გამოიყენეთ „გასვლა“."
          }
        },
        "kk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Пайдаланбайтын құрылғыларды жойыңыз. Ағымдағы құрылғыны мұнда жою мүмкін емес — «Шығу» түймесін қолданыңыз."
          }
        },
        "ky": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Колдонбой калган түзмөктөрдү өчүрүңүз. Учурдагы түзмөктү бул жерден өчүрүүгө болбойт — «Чыгуу» баскычын колдонуңуз."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Pašalinkite įrenginius, kurių nebenaudojate. Dabartinio įrenginio čia pašalinti negalima — naudokite „Atsijungti“."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Noņemiet ierīces, kuras vairs neizmantojat. Pašreizējo ierīci šeit nevar noņemt — izmantojiet “Iziet”."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Elimină dispozitivele pe care nu le mai folosești. Dispozitivul curent nu poate fi eliminat aici — folosește Deconectare."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Удаляйте устройства, которыми не пользуетесь. Текущее устройство отсюда удалить нельзя — используйте «Выйти»."
          }
        },
        "tg": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Дастгоҳҳоеро, ки дигар истифода намебаред, ҳазф кунед. Дастгоҳи ҷориро аз ин ҷо ҳазф кардан мумкин нест — «Баромадан»-ро истифода баред."
          }
        },
        "tk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Indi ulanmaýan enjamlaryňyzy aýyryň. Häzirki enjamy bu ýerden aýryp bolmaýar — «Çyk» düwmesini ulanyň."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Видаляйте пристрої, якими більше не користуєтеся. Поточний пристрій звідси видалити не можна — скористайтеся «Вийти»."
          }
        },
        "uz": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Foydalanmaydigan qurilmalarni oʻchiring. Joriy qurilmani bu yerdan oʻchirib boʻlmaydi — «Chiqish»dan foydalaning."
          }
        }
      }
    },
