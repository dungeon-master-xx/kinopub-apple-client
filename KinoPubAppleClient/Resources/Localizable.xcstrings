    "Try a different title, actor or director.": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Başqa ad, aktyor və ya rejissor sınayın."
          }
        },
        "be": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Паспрабуйце іншую назву, акцёра ці рэжысёра."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Try a different title, actor or director."
          }
        },
        "et": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Proovi muud pealkirja, näitlejat või režissööri."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Փորձեք այլ անվանում, դերասան կամ ռեժիսոր։"
          }
        },
        "ka": {
          "stringUnit": {
            "state": "needs_review",
            "value": "სცადეთ სხვა სათაური, მსახიობი ან რეჟისორი."
          }
        },
        "kk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Басқа атауды, актёрді немесе режиссёрді көріңіз."
          }
        },
        "ky": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Башка аталышты, актёрду же режиссёрду издеп көрүңүз."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Pabandykite kitą pavadinimą, aktorių ar režisierių."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Pamēģiniet citu nosaukumu, aktieri vai režisoru."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Încearcă alt titlu, actor sau regizor."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Попробуйте другое название, актёра или режиссёра."
          }
        },
        "tg": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Номи дигар, ҳунарпеша ё коргардонро санҷед."
          }
        },
        "tk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Başga at, aktýor ýa-da režissýor synanyşyp görüň."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Спробуйте іншу назву, актора або режисера."
          }
        },
        "uz": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Boshqa nom, aktyor yoki rejissyorni sinab koʻring."
          }
        }
      }
    },
