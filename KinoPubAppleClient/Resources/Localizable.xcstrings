          }
        }
      }
    },
    "HLS downloads are stored in the app's private storage (not visible in the Files app) and keep every audio track, so they're larger than the source file.": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "needs_review",
            "value": "HLS yükləmələri tətbiqin xüsusi yaddaşında saxlanılır (Fayllar tətbiqində görünmür) və bütün audio cığırları daxil edir, ona görə də mənbə faylından daha çox yer tutur."
          }
        },
        "be": {
          "stringUnit": {
            "state": "needs_review",
            "value": "HLS-спампоўкі захоўваюцца ў прыватным сховішчы праграмы (не бачныя ў «Файлах») і змяшчаюць усе аўдыядарожкі, таму займаюць больш, чым зыходны файл."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "HLS downloads are stored in the app's private storage (not visible in the Files app) and keep every audio track, so they're larger than the source file."
          }
        },
        "et": {
          "stringUnit": {
            "state": "needs_review",
            "value": "HLS-allalaadimised salvestatakse rakenduse privaatsesse hoidlasse (pole rakenduses Failid nähtavad) ja sisaldavad kõiki helirade, mistõttu need on lähtefailist suuremad."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "needs_review",
            "value": "HLS ներբեռնումները պահվում են հավելվածի մասնավոր պահոցում (Ֆայլերում տեսանելի չեն) և պարունակում են բոլոր ձայնային ուղիները, ուստի զբաղեցնում են ավելի շատ տեղ, քան սկզբնական ֆայլը։"
          }
        },
        "ka": {
          "stringUnit": {
            "state": "needs_review",
            "value": "HLS-ჩამოტვირთვები ინახება აპის პირად საცავში (არ ჩანს Files-ში) და შეიცავს ყველა აუდიოჩანაწერს, ამიტომ უფრო მეტ ადგილს იკავებს, ვიდრე საწყისი ფაილი."
          }
        },
        "kk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "HLS-жүктеулер қолданбаның жеке қоймасында сақталады (Файлдар қолданбасында көрінбейді) және барлық аудиожолды қамтиды, сондықтан бастапқы файлдан үлкенірек болады."
          }
        },
        "ky": {
          "stringUnit": {
            "state": "needs_review",
            "value": "HLS-жүктөөлөр тиркеменин жеке сактагычында сакталат (Файлдар тиркемесинде көрүнбөйт) жана бардык аудиожолдорду камтыйт, ошондуктан баштапкы файлдан көбүрөөк орун ээлейт."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "HLS atsisiuntimai saugomi privačioje programos saugykloje (nematomi programoje „Failai“) ir laiko visus garso takelius, todėl užima daugiau vietos nei pradinis failas."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "needs_review",
            "value": "HLS lejupielādes tiek glabātas lietotnes privātajā krātuvē (nav redzamas lietotnē Faili) un satur visus audio celiņus, tāpēc tās aizņem vairāk vietas nekā avota fails."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Descărcările HLS sunt stocate în spațiul privat al aplicației (nu sunt vizibile în Fișiere) și păstrează toate pistele audio, deci ocupă mai mult decât fișierul sursă."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "HLS-загрузки хранятся в приватном хранилище приложения (не видны в Файлах) и содержат все аудиодорожки, поэтому занимают больше, чем исходный файл."
          }
        },
        "tg": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Боргириҳои HLS дар захираи хусусии барнома нигоҳ дошта мешаванд (дар Files намоён нестанд) ва ҳамаи трекҳои аудиоро дар бар мегиранд, бинобар ин аз файли аслӣ калонтаранд."
          }
        },
        "tk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "HLS-ýüklemeleri programmanyň şahsy ammarynda saklanýar (Faýllar programmasynda görünmeýär) we ähli ses ýollaryny saklaýar, şonuň üçin çeşme faýldan has uludyr."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "HLS-завантаження зберігаються у приватному сховищі застосунку (не видно у «Файлах») і містять усі аудіодоріжки, тому займають більше місця, ніж вихідний файл."
          }
        },
        "uz": {
          "stringUnit": {
            "state": "needs_review",
            "value": "HLS yuklanmalari ilovaning shaxsiy xotirasida saqlanadi (Files ilovasida koʻrinmaydi) va barcha audio yoʻllarni saqlaydi, shuning uchun asl fayldan kattaroq."
          }
        }
      }
    },
