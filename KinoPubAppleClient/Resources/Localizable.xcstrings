    "Auth_CodeActivationText": {
      "extractionState": "manual",
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Əvvəlcə bu cihazı aktivləşdirmək lazımdır. Sayta keçin və profilinizdəki «Cihazın aktivləşdirilməsi» bölməsində kodu daxil edib «Əlavə et» düyməsinə basın. Sonra tətbiqə qayıdın. Kod avtomatik olaraq mübadilə buferinə kopyalanır."
          }
        },
        "be": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Спачатку трэба актываваць гэту прыладу. Перайдзіце на сайт і ў сваім профілі ў графе «Актывацыя прылады» увядзіце код і націсніце «Дадаць». Пасля гэтага вяртайцеся ў праграму. Код аўтаматычна капіюецца ў буфер абмену."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You must activate this device first. Go to the website and enter the code in the \"Device Activation\" section of your profile and press \"Add\". Then return to the app. The code is automatically copied to the clipboard."
          }
        },
        "et": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Esmalt tuleb see seade aktiveerida. Mine veebisaidile ja sisesta oma profiili jaotises „Seadme aktiveerimine“ kood ning vajuta „Lisa“. Seejärel naase rakendusse. Kood kopeeritakse automaatselt lõikelauale."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Սկզբում անհրաժեշտ է ակտիվացնել այս սարքը։ Անցեք կայք և ձեր պրոֆիլում «Սարքի ակտիվացում» բաժնում մուտքագրեք կոդը և սեղմեք «Ավելացնել»։ Այնուհետև վերադարձեք հավելված։ Կոդն ինքնաշխատ պատճենվում է սեղմատախտակում։"
          }
        },
        "ka": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ჯერ უნდა გააქტიუროთ ეს მოწყობილობა. გადადით საიტზე და თქვენს პროფილში, განყოფილებაში „მოწყობილობის გააქტიურება“, შეიყვანეთ კოდი და დააჭირეთ „დამატება“. შემდეგ დაბრუნდით აპში. კოდი ავტომატურად კოპირდება ბუფერში."
          }
        },
        "kk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Алдымен бұл құрылғыны белсендіру қажет. Сайтқа кіріп, профиліңіздегі «Құрылғыны белсендіру» бөлімінде кодты енгізіп, «Қосу» түймесін басыңыз. Содан кейін қолданбаға қайта оралыңыз. Код алмасу буферіне автоматты түрде көшіріледі."
          }
        },
        "ky": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Адегенде бул түзмөктү активдештириш керек. Сайтка кирип, профилиңиздеги «Түзмөктү активдештирүү» бөлүмүнө кодду киргизип, «Кошуу» баскычын басыңыз. Андан соң тиркемеге кайтыңыз. Код буферге автоматтык түрдө көчүрүлөт."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Pirmiausia turite aktyvuoti šį įrenginį. Eikite į svetainę ir savo profilyje skiltyje „Įrenginio aktyvacija“ įveskite kodą ir paspauskite „Pridėti“. Tada grįžkite į programą. Kodas automatiškai nukopijuojamas į iškarpinę."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Vispirms jāaktivizē šī ierīce. Atveriet vietni un sava profila sadaļā “Ierīces aktivizācija” ievadiet kodu un nospiediet “Pievienot”. Pēc tam atgriezieties lietotnē. Kods tiek automātiski nokopēts starpliktuvē."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Mai întâi trebuie să activezi acest dispozitiv. Accesează site-ul, introdu codul în secțiunea „Activarea dispozitivului” din profilul tău și apasă „Adaugă”. Apoi revino în aplicație. Codul este copiat automat în clipboard."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Для начала нужно активировать это устройство. Перейдите на сайт и в своём профиле в графе «Активация устройства» введите код и нажмите «Добавить». После этого возвращайтесь в приложение.  Код автоматически копируется в буфер обмена."
          }
        },
        "tg": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Аввал бояд ин дастгоҳро фаъол кунед. Ба вебсайт гузаред ва дар профили худ дар бахши «Фаъолсозии дастгоҳ» рамзро ворид карда, «Илова кардан»-ро пахш кунед. Сипас ба барнома баргардед. Рамз ба худкорӣ ба клипборд нусхабардорӣ мешавад."
          }
        },
        "tk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Ilki bilen bu enjamy işjeňleşdirmeli. Saýta giriň we profiliňizde «Enjamy işjeňleşdirmek» bölüminde kody giriziň hem-de «Goş» düwmesine basyň. Soňra programma dolanyň. Kod awtomatik usulda alyş-çalyş buferine göçürilýär."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Спершу потрібно активувати цей пристрій. Перейдіть на сайт і у своєму профілі в розділі «Активація пристрою» введіть код і натисніть «Додати». Після цього поверніться до застосунку. Код автоматично копіюється в буфер обміну."
          }
        },
        "uz": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Avval bu qurilmani faollashtirish kerak. Saytga oʻting va profilingizdagi «Qurilmani faollashtirish» boʻlimiga kodni kiriting va «Qoʻshish» tugmasini bosing. Soʻngra ilovaga qayting. Kod avtomatik ravishda almashish buferiga nusxalanadi."
          }
        }
      }
    },
